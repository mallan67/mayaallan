node_modules/
.next/
.vercel/
dist/
.env
.env.*
*.log
*.bak
.vercel
.env*.local
tsconfig.tsbuildinfo
nul
.claude/
!.env.example

# Auto-generated by Next.js — per Next.js docs this file must not be edited
# and should not be tracked. The dev server rewrites it on every run.
next-env.d.ts

# Production audio + design mockups — kept locally, not in git. Use a
# separate object store (Vercel Blob / S3) for production audio assets.
audiobook/
mockups/

# Spelling-extraction artifact (transient output from
# scripts/get-spelling-errors.ps1). Should never be committed.
tmp-spelling.tsv

# Per-script output (extraction reports, source-content reference files
# containing verbatim book text — kept locally, never published or committed).
scripts/output/

# Debug HTML from one-off search engine fetches.
google-*.html

# Operator runbooks / status notes. These tend to accumulate real
# credentials, env-var values, and infra details. Keep them local-only —
# a tracked runbook leaked the production admin password once (see audit).
URGENT-FIX-*.md
*-STATUS-*.md
*-STATUS.md
PAYPAL-STATUS-*.md
AUDIOBOOK-AND-COMPANION-PLAN.md

# =============================================================================
# One-off local tooling / generated artifacts (kept locally, not committed).
# The 3 package.json-referenced scripts are intentionally NOT matched here:
#   scripts/eval-prompts.mjs, scripts/publish-to-medium.mjs,
#   scripts/check-translations.mjs
# =============================================================================
# One-off Python tooling (extraction, audiobook generation, doc builders).
scripts/*.py
scripts/clone-*.py
# One-off node inspect/fix utilities.
scripts/inspect-*.mjs
scripts/fix-nav-items-hrefs.mjs
scripts/test-resend.mjs
scripts/find-author-photo.mjs
scripts/restore-author-photo.mjs
# One-off PowerShell helpers.
scripts/*.ps1
# Generated review documents.
docs/book-review/*.docx
# Admin password hashing tool — must never be committed.
hash-admin-password.mjs


# Python bytecode cache
__pycache__/
*.pyc
