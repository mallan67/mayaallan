SUPABASE_URL=
# Preferred: new sb_secret_* / sb_publishable_* keys (per a85f1ea). Legacy
# SUPABASE_SERVICE_ROLE_KEY / SUPABASE_ANON_KEY accepted as fallback.
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# =========================
# Admin Authentication
# =========================
SESSION_SECRET=generate-a-random-32-character-string
ADMIN_EMAIL=maya@mayaallan.com
# bcrypt hash of the admin password (REQUIRED). Generate locally:
#   node -e "console.log(require('bcryptjs').hashSync('YOUR_PASSWORD', 12))"
# Plaintext ADMIN_PASSWORD is NOT supported — the login route reads only
# ADMIN_PASSWORD_HASH (storing plaintext in Vercel env was a leak risk).
ADMIN_PASSWORD_HASH=

# =========================
# Site / build
# =========================
# REQUIRED in production — src/lib/site-url.ts throws if unset in prod.
NEXT_PUBLIC_SITE_URL=https://www.mayaallan.com

# =========================
# Upstash Redis (REQUIRED in production)
# =========================
# Powers:
#   - session-export staging (chat transcripts + customer email, 24h TTL)
#     replaces the prior public Vercel Blob path (privacy fix AI-001)
#   - distributed rate limiting (deferred — currently per-instance)
# Sign up at upstash.com → create a Redis database → copy URL + REST token.
# Free tier: 10K commands/day, sufficient for current traffic.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# =========================
# Vercel Blob (book files + audiobook + public assets)
# =========================
BLOB_READ_WRITE_TOKEN=

# =========================
# Resend (transactional email — book delivery, PDF delivery, admin alerts)
# =========================
RESEND_API_KEY=
# Reply-To address on customer-facing transactional emails (order confirmations,
# delivery emails). Defaults to hello@mayaallan.com if unset.
SUPPORT_REPLY_TO=

# =========================
# Operator alerting
# =========================
# Optional: prefix admin alert subject lines so a multi-site operator can
# tell at a glance which project triggered.
ALERT_PROJECT_TAG=mayaallan
# Where contact-form notifications + newsletter notifications land. Defaults
# to ADMIN_EMAIL if unset.
CONTACT_EMAIL=
NEWSLETTER_NOTIFY_EMAIL=

# =========================
# PayPal (live + sandbox supported via PAYPAL_ENV)
# =========================
# Two webhook subscriptions: book purchases + session-export. Each must have
# its own webhook ID registered in the PayPal Developer Dashboard.
PAYPAL_ENV=live                  # "live" or "sandbox"
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# Legacy alias for PAYPAL_CLIENT_SECRET, accepted for compatibility with the
# older book-checkout flow. Set PAYPAL_CLIENT_SECRET on new deployments.
PAYPAL_SECRET=
PAYPAL_WEBHOOK_ID=               # book-purchase webhook ID
PAYPAL_EXPORT_WEBHOOK_ID=        # session-export webhook ID
# Optional: PAYPAL_API_BASE overrides the env-derived URL (advanced).

# Number of times a delivery download token may be used before it expires.
# Defaults to 5 if unset.
DOWNLOAD_TOKEN_MAX_DOWNLOADS=

# =========================
# Promo codes (comma-separated, case-insensitive) — bypass PayPal for /api/export
# =========================
PROMO_CODES=

# =========================
# Email (SMTP)
# =========================
SMTP_USER=maya@mayaallan.com
SMTP_PASS=your_email_password

# =========================
# AI Chat (Belief Inquiry / Reset / Integration tools)
# =========================
# Two providers supported:
#   AI_PROVIDER=gateway → Vercel AI Gateway (paid, observability, fallback chains)
#   AI_PROVIDER=direct  → Direct Google AI Studio (free up to ~1500 req/day)
# Default (unset) = gateway. Flip to "direct" to conserve Vercel credits.
AI_PROVIDER=gateway
AI_GATEWAY_API_KEY=                # required when AI_PROVIDER=gateway
GOOGLE_GENERATIVE_AI_API_KEY=      # required when AI_PROVIDER=direct
# Legacy alias accepted by AEO engines for the same Google key.
GOOGLE_GENAI_API_KEY=

# =============================================================================
# Search engine verification (paste codes after verifying each tool)
# =============================================================================
# search.google.com/search-console → Add property → HTML tag method
GOOGLE_SITE_VERIFICATION=
# bing.com/webmasters → Add site → HTML Meta tag
BING_SITE_VERIFICATION=
# webmaster.yandex.com → Add site → Meta tag
YANDEX_VERIFICATION=
# pinterest.com/business → Claim website → HTML tag
PINTEREST_VERIFICATION=
# business.facebook.com → Brand Safety → Domains
FACEBOOK_DOMAIN_VERIFICATION=

# =============================================================================
# IndexNow — instant search engine indexing (Bing, Yandex, DuckDuckGo, ...)
# =============================================================================
# Random alphanumeric, 8-128 chars. UUID without hyphens works.
# Example: openssl rand -hex 16
INDEXNOW_KEY=
# Separate secret for the manual submit endpoint at /api/indexnow/submit
INDEXNOW_SUBMIT_SECRET=

# =============================================================================
# AEO tracker — needs CRON_SECRET + at least one engine key
# See docs/AEO-AND-ANALYTICS-SETUP.md for setup.
# =============================================================================
# Random secret used by Vercel Cron in Authorization: Bearer header
CRON_SECRET=

# Each engine is OPTIONAL. The cron skips any engine whose key isn't set.
# Start with one (Perplexity recommended — highest signal), add more later.
ANTHROPIC_API_KEY=                        # console.anthropic.com → API Keys
OPENAI_API_KEY=                           # platform.openai.com → API keys
PERPLEXITY_API_KEY=                       # perplexity.ai → Settings → API
GOOGLE_GENAI_API_KEY=                     # aistudio.google.com/apikey

# Number of recent AEO runs to keep in Vercel Blob before auto-pruning.
# Default 26 (~6 months of weekly runs). Each run is ~50KB.
AEO_KEEP_RUNS=

# Comma-separated whitelist of AEO engines to run. When set, only these
# engines fire — everything else is skipped. Useful for cost control when
# you only want to probe with one provider.
#   Valid values: claude, chatgpt, perplexity, gemini
#   Examples:
#     AEO_ENGINES=claude              # only Claude (uses your Anthropic credit)
#     AEO_ENGINES=gemini,perplexity   # only the free / search-enabled ones
#   Leave unset = run every engine that has a credential path available.
AEO_ENGINES=

# How many prompts to probe concurrently (each runs all enabled engines
# in parallel internally). Default 5. Lower if you hit per-provider rate
# limits; raise if you have headroom and want faster runs.
AEO_CONCURRENCY=
